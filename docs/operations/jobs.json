  "jobs": [
    {
      "id": "cron-ingest",
      "kind": "ingestion",
      "owner": "sarthak",
      "trigger": { "type": "schedule", "cron": "0 6 * * *", "tz": "UTC" },
      "workflowFile": ".github/workflows/cron-ingest.yml",
      "runtime": "github-actions-ubuntu",
      "command": "uv run python -m high_signal_ingest.pipeline --source all --days 1",
      "workingDirectory": "python/ingest",
      "bounds": { "timeoutMinutes": 45, "concurrency": 1, "retryMax": 0 },
      "idempotency": {
        "mechanism": "events.raw_hash unique index + market_quotes hour-bucket id",
        "watermark": "ingest_runs.started_at per source; events.fetch_run_id",
        "deduplicationEvidence": "packages/db/src/schema.ts events_raw_hash_idx, market_quotes id sha16(source:marketId:hourBucket)"
      },
      "freshness": { "windowHours": 30, "evidenceSource": "ingest_runs.started_at" },
      "outputExpectation": { "minEventsFetched": 0, "minSignalsDrafted": 0, "zeroOutputIsFailure": false },
      "failureDestination": {
        "durableState": "ingest_runs row with errors>0 + error_sample",
        "notification": "github-actions job failure email"
      },
      "evidence": {
        "lifecycleTable": "ingest_runs",
        "rawEventTable": "events",
        "llmAuditTable": "llm_runs",
        "adminEndpoint": "/admin/ingest-runs, /admin/events, /admin/llm-runs"
      },
      "preflight": "python -m high_signal_ingest.source_diagnose --require-persistence --require-sec-identity",
      "acceptedExceptions": []
    },
    {
      "id": "cron-publish",
      "kind": "publish",
      "owner": "sarthak",
      "trigger": { "type": "schedule", "cron": "0 7 * * *", "tz": "UTC" },
      "workflowFile": ".github/workflows/cron-publish.yml",
      "runtime": "github-actions-ubuntu",
      "command": "tsx scripts/auto-publish-drafts.ts --remote",
      "workingDirectory": ".",
      "bounds": { "timeoutMinutes": 15, "concurrency": 1, "retryMax": 0 },
      "idempotency": {
        "mechanism": "signals.review_status transition guard (canTransition) + auto-publish-rules deterministic rubric",
        "watermark": "signals.published_at / review_status='published' or 'killed'",
        "deduplicationEvidence": "scripts/auto-publish-rules.test.ts; canTransition in @high-signal/shared"
      },
      "freshness": { "windowHours": 26, "evidenceSource": "signals.published_at max per day" },
      "outputExpectation": { "minPublishedOrKilled": 0, "zeroOutputIsFailure": false },
      "failureDestination": {
        "durableState": "signals row stays in 'draft' review_status; re-run via workflow_dispatch",
        "notification": "github-actions job failure email"
      },
      "evidence": {
        "lifecycleTable": "signals (review_status, published_at)",
        "adminEndpoint": "/admin/audit/summary (signalsDrafted via ingest_runs; publish outcome via signals)"
      },
      "acceptedExceptions": [
        "HOLD biases to KILL without AI judge — by design (ADR-008)"
      ]
    },
