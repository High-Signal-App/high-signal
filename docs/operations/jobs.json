        "watermark": "apps/web/src/data/daily-source-refreshes.json latestAcceptedDate",
        "deduplicationEvidence": "scripts/daily-automation-status.test.ts; buildDailyAutomationStatus"
      },
      "freshness": { "windowHours": 36, "evidenceSource": "daily-source-refreshes.json latestAcceptedAt" },
