{
  "$schema": "https://high-signal.app/operations/jobs.json",
  "version": 1,
  "project": "high-signal",
  "runtime": "cloudflare-workers + github-actions + python-ingest",
  "owner": "sarthak",
  "generatedFrom": "docs/operations/jobs.md + .github/workflows/*.yml + packages/db/src/schema.ts",
  "notes": [
    "Schedules are authoritative in .github/workflows/*.yml; this file is the automation-readiness registry.",
    "Every recurring path MUST appear here. The coverage audit (scripts/automation-coverage.mjs) validates this against the workflow files and D1 schema.",
    "No secrets, raw payloads, prompts, or private content are persisted in this file or its derived reports."
