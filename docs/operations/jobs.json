      "freshness": { "windowHours": 30, "evidenceSource": "git log -1 workers/api/src/lib/label-backtest.json" },
      "outputExpectation": { "minLabels": 1, "zeroOutputIsFailure": true },
      "failureDestination": {
        "durableState": "stale label-backtest.json (deploy-api auto-redeploys on commit; stale = no redeploy)",
