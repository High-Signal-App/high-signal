{
  "name": "high-signal",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "husky": "9.1.7",
    "next": "16.2.4",
    "tsx": "4.21.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @high-signal/web dev",
    "dev:api": "pnpm --filter @high-signal/api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "node scripts/run-tests.mjs",
    "lint": "pnpm -r lint",
    "db:migrate:local": "pnpm --filter @high-signal/db migrate:local",
    "db:migrate:remote": "pnpm --filter @high-signal/db migrate:remote",
    "db:seed:local": "tsx scripts/seed-d1.ts --local",
    "db:seed:remote": "tsx scripts/seed-d1.ts --remote",
    "product-flow:seed:local": "tsx scripts/seed-product-flow.ts --local",
    "product-flow:seed:remote": "tsx scripts/seed-product-flow.ts --remote",
    "personal:brief": "tsx scripts/personal-command-brief.ts",
    "daily:snapshot": "tsx scripts/build-daily-source-refreshes.ts",
    "market:snapshot": "tsx scripts/build-market-refreshes.ts",
    "price:snapshot": "tsx scripts/build-price-context.ts",
    "equities:snapshot": "tsx scripts/build-equities-snapshot.ts",
    "tickers:bundle": "tsx scripts/build-known-tickers.ts",
    "drank:sync": "tsx scripts/sync-drank-domains.ts",
    "daily:seed-history": "tsx scripts/seed-daily-source-history.ts",
    "d2c:collect": "uv run --project python/ingest python -m high_signal_ingest.d2c_opportunities",
    "d2c:bundle": "tsx scripts/d2c-opportunities-bundle.ts",
    "d2c:agent-visibility": "uv run --project python/ingest python -m high_signal_ingest.d2c_agent_visibility",
    "d2c:sync": "tsx scripts/sync-d2c-opportunities.ts --local",
    "d2c:sync:remote": "tsx scripts/sync-d2c-opportunities.ts --remote",
    "d2c:sync-av": "tsx scripts/sync-d2c-agent-visibility.ts --local",
    "d2c:sync-av:remote": "tsx scripts/sync-d2c-agent-visibility.ts --remote",
    "signals:sync:local": "tsx scripts/sync-signals.ts --local",
    "signals:sync:remote": "tsx scripts/sync-signals.ts --remote",
    "sync:month:local": "pnpm signals:sync:local && pnpm daily:snapshot && pnpm market:snapshot",
    "sync:month:remote": "pnpm signals:sync:remote && pnpm daily:snapshot && pnpm market:snapshot",
    "signals:publish-drafts:local": "tsx scripts/publish-drafts.ts --local",
    "signals:publish-drafts:remote": "tsx scripts/publish-drafts.ts --remote",
    "signals:auto-publish:remote": "tsx scripts/auto-publish-drafts.ts --remote",
    "signals:auto-publish:local": "tsx scripts/auto-publish-drafts.ts --local",
    "signals:auto-publish:dry": "tsx scripts/auto-publish-drafts.ts --remote --dry",
    "signals:auto-publish:reapply": "tsx scripts/auto-publish-drafts.ts --remote --reapply",
    "signals:auto-publish:test": "tsx scripts/auto-publish-rules.test.ts",
    "claim-provenance:test": "tsx scripts/claim-provenance.test.ts",
    "evidence-ranking:test": "tsx scripts/evidence-ranking.test.ts",
    "ai-visibility:test": "tsx scripts/ai-visibility.test.ts",
    "abuse-guard:test": "node scripts/abuse-guard.test.mjs",
    "brief-delivery:test": "tsx scripts/brief-delivery.test.ts",
    "watchlist-impact:test": "tsx scripts/watchlist-impact.test.ts",
    "openlens-visibility:test": "tsx scripts/openlens-visibility.test.ts",
    "intent-opportunities:test": "tsx scripts/intent-opportunities.test.ts",
    "seo:test": "tsx scripts/seo-json-ld.test.ts",
    "signals:test": "tsx scripts/sync-signals.test.ts",
    "requirements:test": "tsx scripts/daily-requirements.test.ts",
    "daily-range:test": "tsx scripts/daily-range.test.ts",
    "source-registry:test": "tsx scripts/source-registry.test.ts",
    "daily-automation:test": "tsx scripts/daily-automation-status.test.ts",
    "daily-source-audit:test": "tsx scripts/daily-source-audit.test.ts",
    "market-snapshot:test": "tsx scripts/market-snapshot.test.ts",
    "competitor-perception:prototype": "tsx scripts/competitor-perception-inbox.ts",
    "competitor-perception:test": "tsx scripts/competitor-perception-inbox.test.ts",
    "youtube:brand-probe": "uv run --project python/ingest python scripts/youtube-brand-awareness-probe.py",
    "company-universe:build": "tsx scripts/build-company-universe.ts",
    "company-universe:sync": "tsx scripts/sync-company-universe.ts --local",
    "company-universe:sync:remote": "tsx scripts/sync-company-universe.ts --remote",
    "task-teardowns:test": "tsx scripts/approved-task-teardowns.test.ts",
    "ingest:local": "cd python/ingest && uv run python -m high_signal_ingest.pipeline --source all --days 1",
    "source:diagnose": "cd python/ingest && uv run python -m high_signal_ingest.source_diagnose",
    "source:quality": "cd python/ingest && uv run python -m high_signal_ingest.source_quality",
    "ingest:preflight": "cd python/ingest && uv run python -m high_signal_ingest.preflight",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "prepare": "husky"
  },
  "pnpm": {
    "overrides": {
      "@cloudflare/workers-types": "4.20260425.1"
    }
  }
}
