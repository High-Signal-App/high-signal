---
import '@/styles/landing.css';
import '@fontsource-variable/geist';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const SITE_URL = 'https://highsignal.app';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="application-name" content="High Signal" />
    <meta name="keywords" content="daily brief, stocks, startups, finance, technology, ai signals, hit-rate, evidence-first, market intelligence, agent evaluation" />
    <meta name="author" content="High Signal" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={SITE_URL} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE_URL} />
    <meta property="og:site_name" content="High Signal" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://highsignal.app/api/og" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="High Signal — Daily Brief" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://highsignal.app/api/og" />
    <meta name="twitter:creator" content="@sarthakagrawal" />
    <style is:global>
      :root {
        --font-geist-sans: 'Geist Variable', ui-sans-serif, system-ui, sans-serif;
      }
    </style>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "High Signal",
      "url": "https://highsignal.app",
      "description": "One daily brief from 20+ noisy public sources — SEC filings, Reddit, Hacker News, YouTube transcripts, GitHub, prediction markets, and more. Every claim cites at least two independent sources.",
      "inLanguage": "en",
      "publisher": {
        "@type": "Organization",
        "name": "High Signal",
        "url": "https://highsignal.app"
      }
    })} />
  </head>
  <body>
    <script is:inline>
      (function () {
        var c = document.cookie;
        if (
          c.indexOf('__session') !== -1 ||
          c.indexOf('__clerk') !== -1 ||
          c.indexOf('__client') !== -1
        ) {
          location.replace('/signals/today');
        }
      })();
    </script>
    <slot />
  </body>
</html>